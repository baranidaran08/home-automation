# ==========================================================
# Public — exposed to the browser (prefix NEXT_PUBLIC_)
# ==========================================================

# Base URL of the backend API (path ends at /api — no version segment).
# In production set this to e.g. https://your-backend.onrender.com/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Application display name.
NEXT_PUBLIC_APP_NAME=Home Automation Admin
