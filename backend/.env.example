# ==========================================================
# Server
# ==========================================================
NODE_ENV=development
PORT=5000

# ==========================================================
# CORS — comma separated list of allowed origins
# ==========================================================
CORS_ORIGIN=http://localhost:3000

# ==========================================================
# MongoDB
# ==========================================================
MONGODB_URI=mongodb://127.0.0.1:27017/home_automation

# ==========================================================
# JWT
# ==========================================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================================
# Auth cookie (httpOnly JWT)
# ==========================================================
AUTH_COOKIE_NAME=ha_access_token
AUTH_COOKIE_MAX_AGE_DAYS=7
# Leave AUTH_COOKIE_DOMAIN empty for localhost; set it in production if needed.
AUTH_COOKIE_DOMAIN=

# ==========================================================
# Password hashing
# ==========================================================
BCRYPT_SALT_ROUNDS=12

# ==========================================================
# Default Admin (used by the seeder — the app has ONE admin, no registration)
# ==========================================================
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@homeautomation.local
ADMIN_PASSWORD=Admin@12345

# ==========================================================
# Cloudinary
# ==========================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=home-automation

# ==========================================================
# File upload limits
# ==========================================================
MAX_FILE_SIZE_MB=10

# ==========================================================
# Outbound email (SMTP) — used for the welcome + reset-password emails.
# All optional: without SMTP_USER/SMTP_PASS the app boots and simply skips
# sending. For Gmail, SMTP_PASS must be a 16-char App Password.
# NOTE: most cloud hosts block outbound SMTP. If sends time out in production,
# use a transactional provider (Brevo/SendGrid/Mailgun) or port 2525.
# ==========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Address in the "From" header; defaults to SMTP_USER.
SMTP_FROM=

# ==========================================================
# Public URLs used INSIDE emails.
# IMPORTANT: in production these must point at the deployed frontend, otherwise
# welcome/reset emails will link to localhost and be unusable.
# ==========================================================
# Login link in the welcome email.
APP_LOGIN_URL=http://localhost:3000/login
# Base URL used to build the reset link: ${FRONTEND_URL}/reset-password?token=...
FRONTEND_URL=http://localhost:3000

# ==========================================================
# Password reset one-time tokens
# ==========================================================
RESET_PASSWORD_EXPIRES_MINUTES=15
