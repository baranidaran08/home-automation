# ==========================================================
# Server
# ==========================================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ==========================================================
# CORS — comma separated list of allowed origins
# ==========================================================
CORS_ORIGIN=http://localhost:3000

# ==========================================================
# MongoDB
# ==========================================================
MONGODB_URI=mongodb://127.0.0.1:27017/home_automation

# ==========================================================
# JWT
# ==========================================================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================================
# Auth cookie (httpOnly JWT)
# ==========================================================
AUTH_COOKIE_NAME=ha_access_token
AUTH_COOKIE_MAX_AGE_DAYS=7
# Leave AUTH_COOKIE_DOMAIN empty for localhost; set it in production if needed.
AUTH_COOKIE_DOMAIN=

# ==========================================================
# Password hashing
# ==========================================================
BCRYPT_SALT_ROUNDS=12

# ==========================================================
# Default Admin (used by the seeder — the app has ONE admin, no registration)
# ==========================================================
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@homeautomation.local
ADMIN_PASSWORD=Admin@12345

# ==========================================================
# Cloudinary
# ==========================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=home-automation

# ==========================================================
# File upload limits
# ==========================================================
MAX_FILE_SIZE_MB=10
